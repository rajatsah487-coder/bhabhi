<title>Amit & Shikha Wedding</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400;1,700&family=Cinzel+Decorative:wght@400;700&family=Noto+Sans+Devanagari:wght@300;400;600;700&family=Cormorant+Garamond:ital,wght@0,400;1,400;1,600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#1a0505;display:flex;align-items:center;justify-content:center;min-height:100vh;font-family:'Cormorant Garamond',serif}

#card{
width:560px;height:800px;
position:relative;overflow:hidden;
background:#6b0f1a;
box-shadow:0 0 0 3px #d4a017,0 0 0 7px #8b1a1a,0 0 0 10px #d4a017,0 0 60px rgba(0,0,0,0.9);
}

/* ── BACKGROUND LAYERS ── */
.bg-base{
position:absolute;inset:0;
background:
radial-gradient(ellipse at 50% 0%,   #9b1a2a 0%,  transparent 55%),
radial-gradient(ellipse at 0%  100%, #4a0a10 0%,  transparent 50%),
radial-gradient(ellipse at 100% 100%,#4a0a10 0%,  transparent 50%),
linear-gradient(180deg,#7a1020 0%,#5a0a15 40%,#6b0f1a 70%,#4a0810 100%);
}
/* Subtle fabric texture via noise-like pattern */
.bg-texture{
position:absolute;inset:0;opacity:.07;
background-image:
repeating-linear-gradient(45deg,#d4a017 0,#d4a017 1px,transparent 0,transparent 50%),
repeating-linear-gradient(-45deg,#d4a017 0,#d4a017 1px,transparent 0,transparent 50%);
background-size:8px 8px;
}

/* ── GOLD ARCH / FRAME ── */
.arch-svg{position:absolute;inset:0;width:100%;height:100%;pointer-events:none}

/* ── TOP KALASH STRIP ── */
.top-strip{
position:absolute;top:0;left:0;right:0;height:52px;
background:linear-gradient(90deg,#8b1a00,#d4a017,#f5d060,#d4a017,#8b1a00);
display:flex;align-items:center;justify-content:center;
font-family:‘Noto Sans Devanagari’,sans-serif;
font-size:13px;color:#3a0000;font-weight:700;letter-spacing:3px;
z-index:6;
}
.bottom-strip{
position:absolute;bottom:0;left:0;right:0;height:10px;
background:linear-gradient(90deg,#8b1a00,#d4a017,#f5d060,#d4a017,#8b1a00);
z-index:6;
}

/* ── SCENES ── */
.scene{
position:absolute;top:52px;left:0;right:0;bottom:10px;
display:flex;flex-direction:column;align-items:center;justify-content:center;
padding:20px 52px 72px;text-align:center;
opacity:0;transition:opacity 1s ease;pointer-events:none;
}
.scene.active{opacity:1;pointer-events:all}

/* ── SHARED COMPONENTS ── */
.gold-divider{display:flex;align-items:center;gap:8px;width:100%;margin:10px 0}
.gold-divider .gl{flex:1;height:1px;background:linear-gradient(90deg,transparent,#d4a017)}
.gold-divider .gr{flex:1;height:1px;background:linear-gradient(90deg,#d4a017,transparent)}
.gold-divider .sym{color:#f5d060;font-size:14px}

/* ── SCENE 1 ── */
#s1 .om-ring{
width:82px;height:82px;border-radius:50%;margin:0 auto 12px;
background:radial-gradient(circle,#f5d060 0%,#d4a017 50%,#8b6200 100%);
display:flex;align-items:center;justify-content:center;
box-shadow:0 0 0 3px rgba(212,160,23,.4),0 0 0 6px rgba(212,160,23,.15),0 8px 30px rgba(0,0,0,.5);
animation:floatOm 3s ease-in-out infinite;
}
@keyframes floatOm{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}
#s1 .om-sym{font-size:38px;color:#3a0000;line-height:1}
#s1 .shloktitle{
font-family:‘Noto Sans Devanagari’,sans-serif;
font-size:15px;color:#f5d060;font-weight:700;letter-spacing:2px;margin-bottom:8px;
}
#s1 .shlok-box{
border:1px solid rgba(212,160,23,.4);
border-left:3px solid #d4a017;border-right:3px solid #d4a017;
background:rgba(0,0,0,.25);
padding:14px 18px;width:100%;
font-family:‘Noto Sans Devanagari’,sans-serif;
font-size:13px;color:#fce8c0;line-height:2.1;
}
#s1 .footer-blessing{
font-family:‘Noto Sans Devanagari’,sans-serif;
font-size:12px;color:#d4a017;margin-top:10px;letter-spacing:1px;
}

/* ── SCENE 2 ── */
#s2 .joy-tag{
font-family:‘Cinzel Decorative’,serif;font-size:8px;
color:#f5d060;letter-spacing:4px;
border:1px solid rgba(212,160,23,.5);padding:5px 16px;margin-bottom:18px;
}
#s2 .g-name{
font-family:‘Playfair Display’,serif;font-size:58px;font-weight:900;font-style:italic;
color:#f5d060;line-height:1;letter-spacing:2px;
text-shadow:0 2px 20px rgba(245,208,96,.3),2px 2px 0 rgba(139,98,0,.5);
}
#s2 .amp{
font-family:‘Playfair Display’,serif;font-size:46px;font-style:italic;
color:rgba(245,208,96,.6);line-height:1;margin:4px 0;
}
#s2 .b-name{
font-family:‘Playfair Display’,serif;font-size:58px;font-weight:900;font-style:italic;
color:#f5d060;line-height:1;letter-spacing:2px;
text-shadow:0 2px 20px rgba(245,208,96,.3),2px 2px 0 rgba(139,98,0,.5);
}
#s2 .hindi-sub{font-family:‘Noto Sans Devanagari’,sans-serif;font-size:12px;color:rgba(245,208,96,.6);letter-spacing:3px;margin-top:10px}
#s2 .parents-wrap{
background:rgba(0,0,0,.3);border:1px solid rgba(212,160,23,.3);
padding:12px 18px;width:100%;margin-top:14px;
}
#s2 .p-lbl{font-family:‘Cinzel Decorative’,serif;font-size:7px;color:#d4a017;letter-spacing:3px;display:block;margin-bottom:6px}
#s2 .p-text{font-size:12.5px;color:#fce8c0;font-style:italic;line-height:2}

/* ── SCENE 3 ── */
#s3 .prog-h{font-family:‘Noto Sans Devanagari’,sans-serif;font-size:22px;font-weight:700;color:#f5d060;margin-bottom:2px}
#s3 .prog-s{font-family:‘Cinzel Decorative’,serif;font-size:7px;letter-spacing:4px;color:rgba(212,160,23,.7);margin-bottom:16px}
.ev-row{
display:flex;align-items:stretch;gap:0;width:100%;margin-bottom:10px;
opacity:0;transform:translateY(16px);transition:all .5s ease;
}
.ev-row.shown{opacity:1;transform:translateY(0)}
.ev-date-col{
background:linear-gradient(180deg,#d4a017,#8b6200);
min-width:58px;display:flex;flex-direction:column;align-items:center;justify-content:center;
padding:10px 6px;
}
.ev-date-col .eday{font-family:‘Playfair Display’,serif;font-size:22px;font-weight:700;color:#3a0000;line-height:1}
.ev-date-col .emon{font-family:‘Cinzel Decorative’,serif;font-size:7px;color:#3a0000;letter-spacing:1px;margin-top:2px}
.ev-info-col{
flex:1;background:rgba(0,0,0,.3);border:1px solid rgba(212,160,23,.25);border-left:none;
padding:10px 14px;text-align:left;
}
.ev-info-col .ev-hindi{font-family:‘Noto Sans Devanagari’,sans-serif;font-size:13px;font-weight:700;color:#f5d060}
.ev-info-col .ev-eng{font-size:11px;color:rgba(252,232,192,.6);font-style:italic;margin-top:2px}
.ev-icon-col{width:40px;background:rgba(0,0,0,.2);border:1px solid rgba(212,160,23,.15);border-left:none;display:flex;align-items:center;justify-content:center;font-size:20px}

/* ── SCENE 4 ── */
#s4 .v-badge{
background:linear-gradient(90deg,#8b1a00,#d4a017,#8b1a00);
color:#3a0000;font-family:‘Cinzel Decorative’,serif;font-size:7px;
letter-spacing:4px;padding:5px 20px;margin-bottom:14px;font-weight:700;
}
#s4 .v-name{
font-family:‘Playfair Display’,serif;font-size:34px;font-weight:900;
color:#f5d060;line-height:1.15;letter-spacing:1px;
text-shadow:0 2px 20px rgba(212,160,23,.3);margin-bottom:8px;
}
#s4 .v-addr{
font-family:‘Noto Sans Devanagari’,sans-serif;
font-size:12px;color:#fce8c0;line-height:2;margin-bottom:12px;
}
#s4 .info-card{
background:rgba(0,0,0,.3);border:1px solid rgba(212,160,23,.3);
border-left:3px solid #d4a017;padding:10px 14px;width:100%;margin-bottom:10px;text-align:left;
}
#s4 .ic-title{font-family:‘Noto Sans Devanagari’,sans-serif;font-size:12px;font-weight:700;color:#f5d060;margin-bottom:4px}
#s4 .ic-body{font-size:12px;color:#fce8c0;line-height:1.9;font-family:‘Noto Sans Devanagari’,sans-serif}

/* ── SCENE 5 ── */
#s5 .ring-anim{font-size:46px;animation:sway 3s ease-in-out infinite;display:block;margin-bottom:10px}
@keyframes sway{0%,100%{transform:rotate(-6deg)}50%{transform:rotate(6deg)}}
#s5 .regards{font-family:‘Cinzel Decorative’,serif;font-size:8px;color:#d4a017;letter-spacing:3px;margin-bottom:12px}
#s5 .fam-name{font-family:‘Noto Sans Devanagari’,sans-serif;font-size:20px;font-weight:700;color:#f5d060;line-height:2;margin-bottom:12px}
#s5 .cg{display:grid;grid-template-columns:1fr 1fr;gap:8px;width:100%;margin-bottom:14px}
.cc{
background:rgba(0,0,0,.3);border:1px solid rgba(212,160,23,.3);
padding:8px;font-family:‘Playfair Display’,serif;
font-size:14px;font-weight:700;color:#f5d060;letter-spacing:1px;
}
#s5 .footer-t{font-family:‘Noto Sans Devanagari’,sans-serif;font-size:13px;color:rgba(252,232,192,.7);font-style:italic;line-height:1.9}
#s5 .final{font-family:‘Playfair Display’,serif;font-size:13px;font-style:italic;color:#d4a017;margin-top:10px;letter-spacing:3px}

/* ── CONTROLS ── */
.controls{
position:absolute;bottom:18px;left:50%;transform:translateX(-50%);
display:flex;gap:8px;z-index:20;
}
.btn{
background:linear-gradient(135deg,#d4a017,#8b6200);
border:none;color:#3a0000;padding:6px 16px;
font-family:‘Cinzel Decorative’,serif;font-size:7px;letter-spacing:2px;
cursor:pointer;text-transform:uppercase;font-weight:700;
box-shadow:0 3px 10px rgba(0,0,0,.4);transition:transform .2s;
}
.btn:hover{transform:translateY(-2px)}
.dots{
position:absolute;bottom:48px;left:50%;transform:translateX(-50%);
display:flex;gap:8px;z-index:20;
}
.dot{width:7px;height:7px;border-radius:50%;background:rgba(212,160,23,.25);transition:all .3s;cursor:pointer}
.dot.active{background:#d4a017;transform:scale(1.6)}
</style>

</head>
