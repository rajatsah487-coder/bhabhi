<script>
const sc=['s1','s2','s3','s4','s5'];
let cur=0,play=true,tmr;
const dotsEl=document.getElementById('dots');
sc.forEach((_,i)=>{const d=document.createElement('div');d.className='dot';d.onclick=()=>go(i);dotsEl.appendChild(d)});

function go(i){
  document.getElementById(sc[cur]).classList.remove('active');
  document.querySelectorAll('.dot')[cur].classList.remove('active');
  cur=(i+sc.length)%sc.length;
  document.getElementById(sc[cur]).classList.add('active');
  document.querySelectorAll('.dot')[cur].classList.add('active');
  if(cur===2){['ec1','ec2','ec3'].forEach((id,j)=>setTimeout(()=>document.getElementById(id)?.classList.add('shown'),200+j*200))}
  if(play){clearTimeout(tmr);tmr=setTimeout(next,5000)}
}
function next(){go(cur+1)}
function prev(){go(cur-1)}
function togglePlay(){
  play=!play;
  document.getElementById('pb').textContent=play?'❚❚ Pause':'▶ Play';
  if(play)tmr=setTimeout(next,5000);else clearTimeout(tmr);
}
go(0);
</script>

